# CVT-VACS Environment Configuration
# Copy this file to .env and update the values

# Application Settings
DEBUG=true
APP_NAME="CVT-VACS API"
APP_VERSION="1.0.0"

# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URL=mongodb+srv://luckynice02:Ben001@vehicleaccess.pqslxqf.mongodb.net/?appName=VehicleAccess
DATABASE_NAME=cvt_vacs_db

# JWT Token Settings
# Generate a secure secret key using: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
TOKEN_EXPIRY_HOURS=24

# Twilio SMS Configuration (Optional)
# Required only if you want to send tokens via SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ANPR Settings
YOLO_MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5
PLATE_CONFIDENCE_THRESHOLD=0.7

# System Settings
MAX_FAILED_ATTEMPTS=3
RATE_LIMIT_PER_MINUTE=60
